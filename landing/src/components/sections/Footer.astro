---
import { useT, type Locale } from '../../i18n/ui';
import LanguageSwitch from '../LanguageSwitch.astro';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
const year = 2026;
---
<footer class="border-t border-[var(--color-line)] bg-[var(--color-surface)]">
  <div class="max-w-[1200px] mx-auto px-6 py-12 flex flex-col sm:flex-row gap-6 justify-between items-center text-sm text-[var(--color-muted)]">
    <div class="flex flex-col items-center sm:items-start gap-1">
      <div class="flex items-center gap-2.5">
        <span class="grid place-items-center w-7 h-7 rounded-[9px] bg-[var(--color-accent)]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round"><path d="M5 19v-8M12 19V5M19 19v-5"/></svg>
        </span>
        <span class="font-[var(--font-display)] font-extrabold text-[var(--color-fg)] text-lg">BulkUp</span>
      </div>
      <p>{t('footer.tagline')}</p>
    </div>
    <LanguageSwitch locale={locale} />
    <p>© {year} BulkUp. {t('footer.rights')}</p>
  </div>
</footer>
