---
import { useT, type Locale } from '../../i18n/ui';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);

const screens = [
  { src: '/import_ai.png', label: t('showcase.import') },
  { src: '/workout.png', label: t('showcase.train') },
  { src: '/diet.png', label: t('showcase.eat') },
  { src: '/progress.png', label: t('showcase.track') },
];
---
<section class="max-w-6xl mx-auto px-6 py-28">
  <Reveal client:visible variant="blur">
    <h2 class="font-[var(--font-display)] text-4xl sm:text-5xl font-black text-center text-balance mb-14">{t('showcase.title')}</h2>
  </Reveal>
  <div class="flex gap-6 overflow-x-auto snap-x pb-6">
    {screens.map((screen, i) => (
      <Reveal client:visible variant="scale" delay={i * 0.08} className="snap-center shrink-0">
        <figure class="w-[240px]">
          <div class="spot w-[240px] h-[500px] rounded-[2rem] border border-[var(--color-line)] bg-[var(--color-surface)] overflow-hidden">
            <img src={screen.src} alt={screen.label} loading="lazy" class="w-full h-full object-cover" />
          </div>
          <figcaption class="mt-4 text-center text-sm text-[var(--color-muted)]">{screen.label}</figcaption>
        </figure>
      </Reveal>
    ))}
  </div>
</section>
