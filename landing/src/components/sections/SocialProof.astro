---
import { useT, type Locale } from '../../i18n/ui';
import CountUp from '../CountUp.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
const count = 250; // swap with live count later
const [before, after] = t('social.title').split('{count}');
---
<section class="bg-[var(--color-surface)]">
  <div class="max-w-[1200px] mx-auto px-6 py-7 text-center text-[var(--color-muted)] text-lg">
    {before}<span class="text-[var(--color-accent)] font-extrabold tabular-nums"><CountUp client:visible to={count} /></span>{after}
  </div>
</section>
