---
import { useT, type Locale } from '../../i18n/ui';
import WaitlistForm from '../WaitlistForm.tsx';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
---
<section id="waitlist" class="max-w-[1200px] mx-auto px-6 py-24">
  <Reveal client:visible variant="up">
    <div class="rounded-[26px] bg-[var(--color-surface)] px-6 py-16 sm:py-20 text-center flex flex-col items-center">
      <h2 class="font-[var(--font-display)] font-extrabold text-3xl sm:text-[2.8rem] leading-[1.1] text-balance mb-4 text-[var(--color-fg)]">{t('cta.title')}</h2>
      <p class="text-lg text-[var(--color-muted)] leading-[1.6] mb-8 max-w-md">{t('cta.subtitle')}</p>
      <div class="flex justify-center w-full">
        <WaitlistForm client:visible locale={locale}
          ctaLabel={t('cta.button')} placeholder={t('hero.placeholder')}
          successMsg={t('form.success')} errorMsg={t('form.error')} invalidMsg={t('form.invalid')} />
      </div>
    </div>
  </Reveal>
</section>
