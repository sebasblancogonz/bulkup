---
import { useT, type Locale } from '../../i18n/ui';
import WaitlistForm from '../WaitlistForm.tsx';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
---
<section
  id="waitlist"
  class="relative isolate grain overflow-hidden"
  style="padding-block: var(--section-pad); scroll-margin-top: 84px;"
>
  <!-- Radial lime glow behind the closing panel -->
  <div
    aria-hidden="true"
    class="glow-pulse pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[640px] w-[640px] max-w-[120vw] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(closest-side, var(--color-accent-glow), transparent 70%);"
  >
  </div>

  <div class="mx-auto w-full max-w-[760px] px-6 text-center">
    <Reveal client:visible variant="up">
      <h2 class="h2 text-balance text-[var(--color-fg)]">{t('cta.title')}</h2>
    </Reveal>

    <Reveal client:visible variant="up" delay={0.12}>
      <p class="text-pretty mx-auto mt-5 max-w-[46ch] text-[var(--color-muted)]">
        {t('cta.subtitle')}
      </p>
    </Reveal>

    <Reveal client:visible variant="up" delay={0.18}>
      <div class="mx-auto mt-9 w-full max-w-[440px]">
        <WaitlistForm
          client:visible
          locale={locale}
          ctaLabel={t('cta.button')}
          placeholder={t('hero.placeholder')}
          successMsg={t('form.success')}
          errorMsg={t('form.error')}
          invalidMsg={t('form.invalid')}
          loadingMsg={t('form.sending')}
          rateMsg={t('form.errorRate')}
          reassure={t('hero.reassure')}
        />
      </div>
    </Reveal>

    <Reveal client:visible variant="up">
      <p
        class="mono mt-6 inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.14em] text-[var(--color-muted)]"
      >
        <span
          aria-hidden="true"
          class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"
          style="box-shadow: 0 0 10px var(--color-accent);"
        ></span>
        {locale === 'es' ? 'Plazas de fundador limitadas.' : 'Limited founder spots.'}
      </p>
    </Reveal>
  </div>
</section>
