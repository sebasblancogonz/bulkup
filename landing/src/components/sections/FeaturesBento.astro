---
import { useT, type Locale } from '../../i18n/ui';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);

// Two-tone section heading: last word in Ember Orange, the rest in Graphite.
const heading = t('features.title');
const lastSpace = heading.lastIndexOf(' ');
const headA = lastSpace >= 0 ? heading.slice(0, lastSpace + 1) : '';
const headB = lastSpace >= 0 ? heading.slice(lastSpace + 1) : heading;

// Alternating phone+text rows (the heroes), then a Fog grid for the rest.
const rows = [
  { k: 'diet', img: '/import_ai.png', tone: 'tone-orange', kicker: 'AI' },
  { k: 'training', img: '/workout.png', tone: 'tone-green', kicker: 'Training' },
  { k: 'body', img: '/progress.png', tone: 'tone-orange', kicker: 'Progress' },
];
const grid = ['rm', 'meals', 'friends'];
---
<section id="features" class="max-w-[1200px] mx-auto px-6 py-24">
  <Reveal client:visible variant="up">
    <h2 class="font-[var(--font-display)] font-extrabold text-3xl sm:text-[2.6rem] leading-[1.15] text-center text-balance max-w-3xl mx-auto mb-20">
      <span class="text-[var(--color-fg)]">{headA}</span><span class="tone-orange">{headB}</span>
    </h2>
  </Reveal>

  <div class="flex flex-col gap-24 sm:gap-28">
    {rows.map((r, i) => (
      <div class={`grid lg:grid-cols-2 gap-10 lg:gap-16 items-center ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}>
        <Reveal client:visible variant="up">
          <div class="max-w-md mx-auto lg:mx-0">
            <p class={`uppercase tracking-[0.16em] text-xs font-bold mb-4 ${r.tone}`}>{r.kicker}</p>
            <h3 class="font-[var(--font-display)] font-extrabold text-[1.9rem] leading-[1.15] mb-4 text-[var(--color-fg)]">{t(`feature.${r.k}.title`)}</h3>
            <p class="text-[var(--color-muted)] text-lg leading-[1.6]">{t(`feature.${r.k}.body`)}</p>
          </div>
        </Reveal>
        <Reveal client:visible variant="scale">
          <div class="flex justify-center">
            <div class="phone w-[240px]">
              <img src={r.img} alt={t(`feature.${r.k}.title`)} loading="lazy" class="w-full h-full object-cover" />
            </div>
          </div>
        </Reveal>
      </div>
    ))}
  </div>

  <div class="grid sm:grid-cols-3 gap-5 mt-24">
    {grid.map((k, i) => (
      <Reveal client:visible variant="up" delay={i * 0.06} className="h-full">
        <article class="lift h-full rounded-[26px] bg-[var(--color-surface)] p-8">
          <h3 class="font-[var(--font-display)] font-bold text-xl mb-2 text-[var(--color-fg)]">{t(`feature.${k}.title`)}</h3>
          <p class="text-[var(--color-muted)] leading-[1.6]">{t(`feature.${k}.body`)}</p>
        </article>
      </Reveal>
    ))}
  </div>
</section>
