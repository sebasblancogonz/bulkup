---
import { useT, type Locale } from '../../i18n/ui';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
---
<section class="max-w-4xl mx-auto px-6 py-28">
  <Reveal client:visible variant="blur">
    <h2 class="font-[var(--font-display)] text-4xl sm:text-5xl font-black text-center text-balance mb-14">{t('pricing.title')}</h2>
  </Reveal>
  <div class="grid sm:grid-cols-2 gap-5">
    <Reveal client:visible variant="up" className="h-full">
      <div class="spot h-full rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-8">
        <p class="text-[var(--color-muted)] mb-2">{t('pricing.monthly')}</p>
      </div>
    </Reveal>
    <Reveal client:visible variant="up" delay={0.1} className="h-full">
      <div class="spot h-full rounded-2xl border border-[var(--color-accent)]/50 bg-[var(--color-surface-2)] p-8">
        <p class="text-[var(--color-accent)] mb-2">{t('pricing.annual')}</p>
        <p class="text-sm text-[var(--color-muted)]">{t('pricing.annualNote')}</p>
      </div>
    </Reveal>
  </div>
  <p class="text-center mt-10">
    <a href="#waitlist" class="sheen press inline-block rounded-full bg-[linear-gradient(95deg,var(--color-accent),var(--color-accent-glow))] text-white font-semibold px-7 py-3.5">{t('pricing.cta')}</a>
  </p>
</section>
