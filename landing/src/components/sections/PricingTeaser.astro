---
import { useT, type Locale } from '../../i18n/ui';
import Reveal from '../Reveal.tsx';
const { locale } = Astro.props as { locale: Locale };
const t = useT(locale);
---
<section id="pricing" class="bg-[var(--color-surface)]">
  <div class="max-w-4xl mx-auto px-6 py-24">
    <Reveal client:visible variant="up">
      <h2 class="font-[var(--font-display)] font-extrabold text-3xl sm:text-[2.4rem] text-center text-balance mb-14 text-[var(--color-fg)]">{t('pricing.title')}</h2>
    </Reveal>
    <div class="grid sm:grid-cols-2 gap-5">
      <Reveal client:visible variant="up" className="h-full">
        <div class="lift h-full rounded-[26px] bg-white border border-[var(--color-line)] p-8">
          <p class="font-[var(--font-display)] font-bold text-xl text-[var(--color-fg)]">{t('pricing.monthly')}</p>
        </div>
      </Reveal>
      <Reveal client:visible variant="up" delay={0.1} className="h-full">
        <div class="lift h-full rounded-[26px] bg-white border-2 border-[var(--color-green)] p-8">
          <p class="font-[var(--font-display)] font-bold text-xl tone-green">{t('pricing.annual')}</p>
          <p class="text-sm text-[var(--color-muted)] mt-1">{t('pricing.annualNote')}</p>
        </div>
      </Reveal>
    </div>
    <p class="text-center mt-10">
      <a href="#waitlist" class="press inline-flex items-center gap-2 rounded-[26px] bg-[var(--color-accent)] text-white font-bold px-7 py-3.5">
        {t('pricing.cta')}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </p>
  </div>
</section>
