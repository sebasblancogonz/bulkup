# Resend — create at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Sender for the waitlist confirmation email — must use a domain verified in Resend.
# Optional: falls back to "BulkUp <waitlist@getbulkup.com>" if unset.
RESEND_FROM=BulkUp <waitlist@getbulkup.com>
# Optional — bucket confirmed signups into a Resend Segment (replaces Audiences).
# https://resend.com/docs/dashboard/segments/migrating-from-audiences-to-segments
RESEND_SEGMENT_ID=

# HMAC secret for stateless waitlist confirm tokens — generate with: openssl rand -base64 32
WAITLIST_TOKEN_SECRET=replace-with-a-32-byte-random-secret

# Upstash Redis (rate limiting). Optional locally — limits no-op if unset. https://upstash.com
# On Vercel KV these are auto-injected as KV_REST_API_URL / KV_REST_API_TOKEN
# (the read-WRITE token), which the code also reads — no manual aliasing needed.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
