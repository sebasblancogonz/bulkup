# Resend — create at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Verified sender for the welcome email — must use a domain verified in Resend.
# If unset, the contact is still created but no welcome email is sent.
RESEND_FROM=BulkUp <hello@getbulkup.com>
# Optional — bucket waitlist signups into a Resend Segment (replaces Audiences).
# https://resend.com/docs/dashboard/segments/migrating-from-audiences-to-segments
RESEND_SEGMENT_ID=
